{
  "$schema": "../schemas/docs.config.schema.json",
  "spec_version": "1",
  "target_repo": "../path/to/your/repo",
  "output_dir": "./analyses",
  "include": [
    "src/**",
    "packages/**",
    "apps/**",
    "*.json",
    "*.ts",
    "*.tsx",
    "*.js",
    "*.sql",
    "*.md"
  ],
  "exclude": [
    "node_modules/**",
    ".git/**",
    "**/*.lock",
    "**/*.lockb",
    "dist/**",
    "build/**",
    ".next/**",
    ".turbo/**"
  ],
  "groups": [
    {
      "name": "by-package",
      "pattern": "packages/{group}/**",
      "summary": "packages/{group}/_SUMMARY.md"
    },
    {
      "name": "by-app",
      "pattern": "apps/{group}/**",
      "summary": "apps/{group}/_SUMMARY.md"
    }
  ],
  "kinds": {
    "test":      ["**/*.test.*", "**/*.spec.*"],
    "config":    ["*.json", "tsup.config.*", "*.config.*", ".eslintrc*", "tailwind.config.*"],
    "dist":      ["**/dist/**", "**/build/**"],
    "sql":       ["**/*.sql"],
    "component": ["**/*.tsx"],
    "type":      ["**/types.ts", "**/types/*.ts"]
  },
  "force_proportional": ["dist", "generated"],
  "tools": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "branches": {
    "_doc": "Spec v1.8 branch parity. Default mode 'single' preserves prior single-branch behavior. Set mode to 'parity' to keep one docs branch per target branch; in parity mode target_repo is derived as <target_worktree_root>/<docs-branch-name> and the runner enforces docs-branch-name === target-branch-name on every command.",
    "mode": "single",
    "target_worktree_root": "../worktrees",
    "pin_model": "claude-opus-4-6",
    "require_clean_target": true
  },
  "compliance": {
    "frameworks": ["hipaa", "soc2", "iso27001", "gdpr", "ccpa", "cmia", "ca-misc"],
    "jurisdictions": ["EU", "US-CA", "US-federal"],
    "required_controls": {
      "gdpr":    ["art-17", "art-25", "art-30", "art-32", "art-33", "art-34"],
      "ccpa":    ["1798.100", "1798.105", "1798.120", "1798.82", "gpc"],
      "hipaa":   ["164.312(a)(1)", "164.312(b)", "164.312(c)(1)", "164.312(d)", "164.312(e)(1)"],
      "soc2":    ["CC6.1", "CC6.2", "CC6.7", "CC7.2", "CC7.3"],
      "iso27001":["A.5.15", "A.8.5", "A.8.10", "A.8.15", "A.8.24"],
      "cmia":    ["56.101", "56.103"]
    },
    "intent_rules": [
      {
        "name": "Files handling PII must cite GDPR Art.32 and CCPA 1798.150",
        "when": { "tags_include": "pii" },
        "require": {
          "compliance_framework_includes": {
            "gdpr": ["art-32"],
            "ccpa": ["1798.150"]
          }
        }
      }
    ]
  }
}
